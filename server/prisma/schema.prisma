datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id        String   @id @default(cuid())
  username  String   @unique
  email     String   @unique
  avatarUrl String?
  level     Int      @default(1)
  createdAt DateTime @default(now())
  
  results   RaceResult[]
  sessions  TypingSession[]
  charStats CharacterStat[]
}

model RaceResult {
  id        String   @id @default(cuid())
  wpm       Float
  accuracy  Float
  date      DateTime @default(now())
  
  userId    String
  user      User     @relation(fields: [userId], references: [id])
}

model TypingSession {
  id        String   @id @default(cuid())
  wpm       Float
  accuracy  Float
  duration  Int      // in seconds
  mode      String   // e.g. "time", "words"
  date      DateTime @default(now())
  
  userId    String
  user      User     @relation(fields: [userId], references: [id])
}

model CharacterStat {
  id           String @id @default(cuid())
  char         String // the character targeted
  correctCount Int    @default(0)
  totalCount   Int    @default(0)
  
  userId       String
  user         User   @relation(fields: [userId], references: [id])

  @@unique([userId, char])
}
